<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Study Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; padding-top: 20px; }
        .card { transition: transform 0.2s; border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .card:hover { transform: translateY(-5px); }
        .btn-study { background-color: #007bff; color: white; width: 100%; }
        header { margin-bottom: 30px; text-align: center; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1 class="display-5 fw-bold">Study Resources</h1>
        <p class="text-muted">Access all your topic materials in one place.</p>
    </header>

    <div class="row g-4" id="links-container">
        </div>
</div>

<script>
    /* ADMIN SECTION: 
       To add a new link, copy a block below and paste it into the array.
    */
    const linksData = [
        {
            title: "Nail Clipper Secret Functions",
            description: "A short guide on the hidden features of common nail clippers.",
            url: "https://www.youtube.com/shorts/n1RT-mM7PgE"
        },
        {
            title: "Acharya Prashant: Life in India",
            description: "A deep dive into social awareness and spiritual growth with Acharya Prashant.",
            url: "https://www.youtube.com/watch?v=nDEb_YvA6H4"
        },
        {
            title: "Funny Ball Pool Unboxing",
            description: "Short entertainment video featuring a creative ball-swimming pool setup.",
            url: "https://www.youtube.com/shorts/Ff3LjYc0rdw"
        }
    ];

    // Logic to display the links
    const container = document.getElementById('links-container');

    linksData.forEach(item => {
        const cardHtml = `
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 p-3">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">${item.title}</h5>
                        <p class="card-text text-secondary small">${item.description}</p>
                        <div class="mt-auto">
                            <a href="${item.url}" target="_blank" class="btn btn-study">Open Material</a>
                        </div>
                    </div>
                </div>
            </div>
        `;
        container.innerHTML += cardHtml;
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
